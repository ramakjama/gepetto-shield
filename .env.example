# ═══════════════════════════════════════════════
# COPILOT OCCIDENT — Environment Variables
# ═══════════════════════════════════════════════

# ── Database ──
DATABASE_URL="postgresql://copilot:copilot_dev_2026@localhost:5433/gepetto_shield"
POSTGRES_PASSWORD="copilot_dev_2026"

# ── Redis ──
REDIS_URL="redis://localhost:6380"

# ── Qdrant Vector Store ──
QDRANT_URL="http://localhost:6334"
QDRANT_API_KEY=""

# ── JWT Authentication (RS256) ──
# Generate keypair: openssl genrsa -out private.pem 4096 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY=""
JWT_PUBLIC_KEY=""
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="8h"

# ── HMAC Context Signing ──
# Generate: openssl rand -hex 64
CONTEXT_HMAC_KEY=""

# ── MFA ──
MFA_ISSUER="Gepetto Shield"

# ── LLM Providers ──
AZURE_OPENAI_API_KEY=""
AZURE_OPENAI_ENDPOINT=""
AZURE_OPENAI_DEPLOYMENT=""
GROQ_API_KEY=""
GEMINI_API_KEY=""

# ── LlamaGuard / Azure Content Safety ──
AZURE_CONTENT_SAFETY_KEY=""
AZURE_CONTENT_SAFETY_ENDPOINT=""

# ── Application ──
NODE_ENV="development"
API_PORT=4025
WEB_PORT=3025
API_URL="http://localhost:4025"

# ── Security ──
BCRYPT_ROUNDS=12
MAX_CONCURRENT_SESSIONS=1
RATE_LIMIT_DEFAULT=20
CIRCUIT_BREAKER_THRESHOLD=1

# ── Audit ──
AUDIT_RETENTION_DAYS=2555
